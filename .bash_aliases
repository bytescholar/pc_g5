# Clear - limpar tela
alias c='clear'

# Sair
alias e='exit'

# Flatpak install [package]
alias flatinst='sudo flatpak install -y flathub'

# Flatpak uninstall [package]
alias flatunin='sudo flatpak uninstall --force-remove --delete-data'

# Abrir Vim
alias v='vim'

# Script de atualização
alias atu='atualiza.sh'
